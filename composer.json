{
  "name": "ez-php/testing-application",
  "version": "0.9.3",
  "description": "Framework-coupled test base classes for ez-php — ApplicationTestCase, DatabaseTestCase, HttpTestCase",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["testing", "test-case", "phpunit", "php", "framework", "ez-php"],
  "homepage": "https://github.com/ez-php/testing-application",
  "support": {
    "issues": "https://github.com/ez-php/testing-application/issues",
    "source": "https://github.com/ez-php/testing-application"
  },
  "require": {
    "php": "^8.5",
    "phpunit/phpunit": "^13.0",
    "ez-php/contracts": "0.*",
    "ez-php/framework": "0.*",
    "ez-php/http": "0.*",
    "ez-php/testing": "0.*"
  },
  "require-dev": {
    "ez-php/docker": "0.*",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Testing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
